{% set chatbotName = chatbotName ?? 'Assistent' %}
{% set primaryColor = primaryColor ?? '006bc2' %}
{% set chatWidth = chatWidth ?? 300 %}
{% set chatHeight = chatHeight ?? 500 %}
{% set welcomeMessage = welcomeMessage|replace({ '{name}': chatbotName }) %}

{% include 'json-plugin/_placeholder-style' with {
    primaryColor: primaryColor
} %}

{% include 'json-plugin/_placeholder-html' with {
    primaryColor: primaryColor,
    chatbotName: chatbotName,
    chatWidth: chatWidth,
    chatHeight: chatHeight,
    welcomeMessage: welcomeMessage
} %}

{% include 'json-plugin/_placeholder-script' with {
    primaryColor: primaryColor,
    chatbotName: chatbotName,
    chatWidth: chatWidth,
    chatHeight: chatHeight,
    welcomeMessage: welcomeMessage,
    maxVraagLength: maxVraagLength ?? 500
} %}
