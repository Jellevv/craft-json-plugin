{% set chatbotName = chatbotName ?? 'Assistent' %}
{% set primaryColor = primaryColor ?? '006bc2' %}
{% set chatWidth = chatWidth ?? 300 %}
{% set chatHeight = chatHeight ?? 500 %}
{% set welcomeMessage = welcomeMessage|replace({ '{name}': chatbotName }) %}
{% set maxVraagLength = maxVraagLength ?? 500 %}

<div class="chat-wrapper collapsed"
    data-csrf="{{ craft.app.request.csrfToken }}"
    data-color="#{{ primaryColor }}"
    data-width="{{ chatWidth }}"
    data-height="{{ chatHeight }}"
    data-chatbot-name="{{ chatbotName }}"
    data-welcome-message="{{ welcomeMessage }}"
    data-max-vraag-length="{{ maxVraagLength }}">

    <header class="chat-header" style="background: #{{ primaryColor }};">
        <h2 class="chat-header-text" style="margin:0; font-size: 16px;">Heeft u een vraag?</h2>
        <div style="display:flex; gap: 8px; align-items: center;">
            <span class="chat-reset" title="Reset gesprek">↺</span>
            <span class="chat-icon">+</span>
        </div>
    </header>

    <main class="chat-container">
        <div class="chat-entry assistant">{{ welcomeMessage }}</div>
    </main>

    <div class="input-container">
        <input type="text" class="vraag" placeholder="Typ je vraag..." autocomplete="off" />
        <button class="verstuur" style="background: #{{ primaryColor }};">Verstuur</button>
    </div>

</div>
