{% import '_includes/forms' as forms %}

<div id="tab-statistieken" class="{{ selectedTab != 'statistieken' ? 'hidden' : '' }}">

	<div class="field">
		<div class="heading">
			<label>Hier kan je alle statistieken van de chatbot zien.</label>
		</div>
		<div class="warning">
			<p>Let op: Fallback data is niet beschikbaar als de fallback switch uit staat in de 'Instellingen' tab.</p>
		</div>
	</div>

	<div class="stats-header-grid">
		<h2>Aantal vragen en fallback antwoorden</h2>

		<div class="stats-controls-middle">
			<div class="stats-flex-group" style="gap: 5px;">
				<a href="?tab=statistieken&period=day" class="btn {{ craft.app.request.getParam('period') == 'day' ? 'submit' : '' }}">Dag</a>
				<a href="?tab=statistieken&period=week" class="btn {{ craft.app.request.getParam('period', 'week') == 'week' ? 'submit' : '' }}">Week</a>
				<a href="?tab=statistieken&period=month" class="btn {{ craft.app.request.getParam('period') == 'month' ? 'submit' : '' }}">Maand</a>
			</div>

			<div class="stats-flex-group">
				<strong id="stats-period-title" class="stats-period-display"></strong>
				<input type="text" id="stats-datepicker" class="datepicker-hidden"/>
				<a id="stats-calendar-btn" class="btn" style="cursor: pointer; display: flex; align-items: center;">
					<svg width="24" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
						<path d="M3 9H21M7 3V5M17 3V5M6.2 21H17.8C18.9201 21 19.4802 21 19.908 20.782C20.2843 20.5903 20.5903 20.2843 20.782 19.908C21 19.4802 21 18.9201 21 17.8V8.2C21 7.07989 21 6.51984 20.782 6.09202C20.5903 5.71569 20.2843 5.40973 19.908 5.21799C19.4802 5 18.9201 5 17.8 5H6.2C5.0799 5 4.51984 5 4.09202 5.21799C3.71569 5.40973 3.40973 5.71569 3.21799 6.09202C3 6.51984 3 7.07989 3 8.2V17.8C3 18.9201 3 19.4802 3.21799 19.908C3.40973 20.2843 3.71569 20.5903 4.09202 20.782C4.51984 21 5.07989 21 6.2 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
					</svg>
				</a>
			</div>
		</div>
	</div>

	<canvas id="stats-chart" class="chart-canvas chart-canvas-main"></canvas>

	<div class="stats-section-hourly">
		<div class="stats-header-grid">
			<h2>Drukste momenten (per uur)</h2>

			<div class="stats-controls-middle">
				<div class="stats-flex-group">
					<strong id="hourly-stats-period-title" class="stats-period-display">
						{{ selectedHourlyDate|date('j F Y') }}
					</strong>
					<input type="text" id="hourly-stats-datepicker" class="datepicker-hidden"/>
					<a id="hourly-stats-calendar-btn" class="btn" style="cursor: pointer; display: flex; align-items: center;">
						<svg width="24" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
							<path d="M3 9H21M7 3V5M17 3V5M6.2 21H17.8C18.9201 21 19.4802 21 19.908 20.782C20.2843 20.5903 20.5903 20.2843 20.782 19.908C21 19.4802 21 18.9201 21 17.8V8.2C21 7.07989 21 6.51984 20.782 6.09202C20.5903 5.71569 20.2843 5.40973 19.908 5.21799C19.4802 5 18.9201 5 17.8 5H6.2C5.0799 5 4.51984 5 4.09202 5.21799C3.71569 5.40973 3.40973 5.71569 3.21799 6.09202C3 6.51984 3 7.07989 3 8.2V17.8C3 18.9201 3 19.4802 3.21799 19.908C3.40973 20.2843 3.71569 20.5903 4.09202 20.782C4.51984 21 5.07989 21 6.2 21Z" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
						</svg>
					</a>
				</div>
			</div>
		</div>
		<canvas id="hourly-stats-chart" class="chart-canvas chart-canvas-hourly"></canvas>
	</div>

	<script>
		window.statsData = {{ stats|json_encode|raw }};
window.hourlyStatsData = {{ hourlyStats|json_encode|raw }};
window.statsPeriod = '{{ statsPeriod }}';
window.statsOffset = {{ statsOffset }};
	</script>
</div>
