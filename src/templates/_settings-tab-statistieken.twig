{% import '_includes/forms' as forms %}

<div id="tab-statistieken" class="{{ selectedTab != 'statistieken' ? 'hidden' : '' }}">
	<div class="field">
		<div class="heading">
			<label>Hier kan je alle statestieken van de chatbot zien.</label>
		</div>
		<div class="warning">
			<p>Let op: Fallback data is niet beschikbaar als de fallback switch uit staat in de 'Instellingen' tab.</p>
		</div>
	</div>

	<div style="margin-bottom: 20px;">
		<a href="?tab=statistieken&period=day" class="btn {{ craft.app.request.getParam('period') == 'day' ? 'submit' : '' }}">Vandaag</a>
		<a href="?tab=statistieken&period=week" class="btn {{ craft.app.request.getParam('period', 'week') == 'week' ? 'submit' : '' }}">Week</a>
		<a href="?tab=statistieken&period=month" class="btn {{ craft.app.request.getParam('period') == 'month' ? 'submit' : '' }}">Maand</a>
	</div>

	<div style="display: flex; align-items: center; gap: 12px; margin-bottom: 16px;">
		<strong id="stats-period-title"></strong>
		<input type="text" id="stats-datepicker" style="width: 0; opacity: 0; position: absolute;"/>
		<a id="stats-calendar-btn" class="btn" style="cursor: pointer;">
			<svg width="30" viewbox="-2.4 -2.4 28.80 28.80" fill="none" xmlns="http://www.w3.org/2000/svg" transform="matrix(1, 0, 0, 1, 0, 0)rotate(0)">
				<g id="SVGRepo_bgCarrier" stroke-width="0" transform="translate(0,0), scale(1)"></g>
				<g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round" stroke="#CCCCCC" stroke-width="0.048"></g>
				<g id="SVGRepo_iconCarrier">
					<path d="M3 9H21M7 3V5M17 3V5M6 12H8M11 12H13M16 12H18M6 15H8M11 15H13M16 15H18M6 18H8M11 18H13M16 18H18M6.2 21H17.8C18.9201 21 19.4802 21 19.908 20.782C20.2843 20.5903 20.5903 20.2843 20.782 19.908C21 19.4802 21 18.9201 21 17.8V8.2C21 7.07989 21 6.51984 20.782 6.09202C20.5903 5.71569 20.2843 5.40973 19.908 5.21799C19.4802 5 18.9201 5 17.8 5H6.2C5.0799 5 4.51984 5 4.09202 5.21799C3.71569 5.40973 3.40973 5.71569 3.21799 6.09202C3 6.51984 3 7.07989 3 8.2V17.8C3 18.9201 3 19.4802 3.21799 19.908C3.40973 20.2843 3.71569 20.5903 4.09202 20.782C4.51984 21 5.07989 21 6.2 21Z" stroke="#000000" stroke-width="2" stroke-linecap="round"></path>
				</g>
			</svg>
		</a>
	</div>

	<canvas id="stats-chart" style="max-height: 400px;"></canvas>

	<script>
		window.statsData = {{ stats|json_encode|raw }};
window.hourlyStatsData = {{ hourlyStats|json_encode|raw }}; // Deze moet er nu bij
window.statsPeriod = '{{ statsPeriod }}';
window.statsOffset = {{ statsOffset }};
	</script>
</div>
