{% import '_includes/forms' as forms %}

<div id="tab-instellingen" class="{{ selectedTab != 'instellingen' ? 'hidden' : '' }}">
	<div class="field">
		<div class="heading">
			<label>Hier kan je alle gegevens, voorwaarden en opmaak van de chatbot instellen.</label>
		</div>
		<div class="warning">
			<p>Let op: Niet verplichte velden die je leeg laat nemen automatisch de waarden van de placeholders.</p>
		</div>

		{{ forms.selectField({ label: 'AI Provider', instructions: 'Welke AI provider wil je gebruiken? \n(OpenAI bevat embedding. Embedding is iets trager maar veel goedkoper. Geen Embedding zal veel tokens kosten.)', id: 'aiProvider', name: 'aiProvider', value: settings.aiProvider, options: [{ label: 'OpenAI (ChatGpt) + embedding', value: 'openai' }, { label: 'Groq (Llama)', value: 'groq' }, { label: 'Anthropic (Claude)', value: 'claude' }, { label: 'Google (Gemini)', value: 'gemini' }] }) }}

		{{ forms.autosuggestField({ label: 'OpenAI API Key', instructions: 'Voer je OpenAI API sleutel in. Je doet dit door een ENV variabele te gebruiken, bijv: $OPENAI_API_KEY', id: 'openaiApiKey', name: 'openaiApiKey', value: settings.openaiApiKey, placeholder: 'sk-...', suggestEnvVars: true, required: true }) }}

		{{ forms.selectField({ label: 'OpenAI Model', instructions: 'Welk model moet de chatbot gebruiken?', id: 'openaiModel', name: 'openaiModel', value: settings.openaiModel, options: [{ label: 'GPT-4o Mini (snel & goedkoop)', value: 'gpt-4o-mini' },{ label: 'GPT-4o', value: 'gpt-4o' },{ label: 'GPT-4.1 Mini', value: 'gpt-4.1-mini' },{ label: 'GPT-4.1', value: 'gpt-4.1' },{ label: 'GPT-5.4 Mini', value: 'gpt-5.4-mini' },{ label: 'GPT-5.4 (krachtig)', value: 'gpt-5.4' }] }) }}

		{{ forms.autosuggestField({ label: 'Groq API Key', instructions: 'Voer je Groq API sleutel in. Je doet dit door een ENV variabele te gebruiken, bijv: $GROQ_API_KEY', id: 'groqApiKey', name: 'groqApiKey', value: settings.groqApiKey, placeholder: 'gsk_...', suggestEnvVars: true, required: true }) }}

		{{ forms.selectField({ label: 'Groq Model', instructions: 'Welk Groq model moet de chatbot gebruiken?', id: 'groqModel', name: 'groqModel', value: settings.groqModel, options: [{ label: 'Llama 3.3 70B (aanbevolen)', value: 'llama-3.3-70b-versatile' },{ label: 'Llama 3.1 8B (snel & goedkoop)', value: 'llama-3.1-8b-instant' },{ label: 'Llama 4 Scout 17B', value: 'meta-llama/llama-4-scout-17b-16e-instruct' },{ label: 'Llama 4 Maverick 17B', value: 'meta-llama/llama-4-maverick-17b-128e-instruct' },{ label: 'Qwen3 32B', value: 'qwen/qwen3-32b' }] }) }}

		{{ forms.autosuggestField({ label: 'Claude API Key', instructions: 'Voer je Anthropic API sleutel in. Je doet dit door een ENV variabele te gebruiken, bijv: $CLAUDE_API_KEY', id: 'claudeApiKey', name: 'claudeApiKey', value: settings.claudeApiKey, placeholder: 'sk-ant-...', suggestEnvVars: true, required: true }) }}

		{{ forms.selectField({ label: 'Claude Model', instructions: 'Welk Claude model moet de chatbot gebruiken?', id: 'claudeModel', name: 'claudeModel', value: settings.claudeModel, options: [{ label: 'Claude Sonnet 4.6 (aanbevolen)', value: 'claude-sonnet-4-6' }, { label: 'Claude Opus 4.6 (krachtig)', value: 'claude-opus-4-6' }, { label: 'Claude Haiku 4.5 (snel & goedkoop)', value: 'claude-haiku-4-5-20251001' }] }) }}

		{{ forms.autosuggestField({ label: 'Gemini API Key', instructions: 'Voer je Google API sleutel in. Je doet dit door een ENV variabele te gebruiken, bijv: $GEMINI_API_KEY', id: 'geminiApiKey', name: 'geminiApiKey', value: settings.geminiApiKey, placeholder: 'AIza...', suggestEnvVars: true, required: true }) }}

		{{ forms.selectField({ label: 'Gemini Model', instructions: 'Welk Gemini model moet de chatbot gebruiken?', id: 'geminiModel', name: 'geminiModel', value: settings.geminiModel, options: [{ label: 'Gemini 2.5 Flash (aanbevolen)', value: 'gemini-2.5-flash' },{ label: 'Gemini 2.5 Flash Lite (snel & goedkoop)', value: 'gemini-2.5-flash-lite' },{ label: 'Gemini 2.5 Pro (krachtig)', value: 'gemini-2.5-pro' },{ label: 'Gemini 3.1 Flash Lite (preview)', value: 'gemini-3.1-flash-lite-preview' },{ label: 'Gemini 3.1 Pro (preview)', value: 'gemini-3.1-pro-preview' }] }) }}
		
		{{ forms.textField({ label: 'Temperature', instructions: 'Hoe creatief mag het model zijn? (0 = strikt en feitelijk, 1 = creatief, max 2). Het is aangeraden om onder 1 te blijven.', id: 'temperature', name: 'temperature', value: settings.temperature, placeholder: '0.5' }) }}

		{{ forms.textField({ label: 'Max antwoordlengte (tokens)', instructions: 'Hoe lang mag het antwoord maximaal zijn? (50 = zeer kort, 300 = normaal, 2000 = zeer lang. 1 token ≈ 0.75 woorden) (min. 50, max. 2000)', id: 'maxTokens', name: 'maxTokens', value: settings.maxTokens, placeholder: '300' }) }}

		{{ forms.textField({ label: 'Max vraaglengte (tekens)', instructions: 'Maximaal aantal tekens dat een gebruiker in één vraag mag typen. (min. 10, max. 2000)', id: 'maxVraagLength', name: 'maxVraagLength', value: settings.maxVraagLength, placeholder: '500' }) }}

		{{ forms.textField({ label: 'Rate limit (vragen per uur)', instructions: 'Maximaal aantal vragen per IP-adres per uur. Let op: gebruikers achter hetzelfde netwerk delen dit limiet. (min. 1, max. 500)', id: 'rateLimit', name: 'rateLimit', value: settings.rateLimit, placeholder: '50' }) }}

		{{ forms.textField({ label: 'Max embedding entries (enkel in te vullen bij een actieve OpenAI key)', instructions: 'Hoeveel relevante entries mogen er per vraag maximaal worden opgehaald? (min. 1, max. 100)', id: 'embeddingTopK', name: 'embeddingTopK', value: settings.embeddingTopK, placeholder: '3' }) }}

		{{ forms.textField({ label: 'Max chunk (enkel in te vullen bij een actieve OpenAI key)', instructions: 'Hoe groot mag 1 embedding zijn? Wordt pas doorgevoerd bij de volgende sync in de "configuratie" tab (min. 200, max. 2000)', id: 'embeddingChunkSize', name: 'embeddingChunkSize', value: settings.embeddingChunkSize, placeholder: '500' }) }}

		{{ forms.textField({ label: 'Chatbot naam', instructions: 'De naam van de chatbot, zichtbaar voor bezoekers.', id: 'chatbotName', name: 'chatbotName', value: settings.chatbotName, placeholder: 'Assistent', required: true }) }}

		{{ forms.textareaField({ label: 'Systeem prompt', instructions: 'De instructies die de chatbot meekrijgt. Beschrijf hier de persoonlijkheid, beperkingen en het gedrag. \n Tip: De standaardwaarde is minimaal — het is sterk aangeraden deze uit te breiden. Bekijk de README voor een voorbeeld.', id: 'systemPrompt', name: 'systemPrompt', value: settings.systemPrompt, rows: 6 }) }}

		<hr/>

		{{ forms.colorField({ label: 'Primaire kleur', instructions: 'Kleur van de header en knoppen. (Niks invullen = #006bc2)', id: 'primaryColor', name: 'primaryColor', value: settings.primaryColor }) }}

		{{ forms.textField({ label: 'Breedte (px)', instructions: 'Minimaal 280px, maximaal 600px.', id: 'chatWidth', name: 'chatWidth', value: settings.chatWidth, placeholder: '300' }) }}

		{{ forms.textField({ label: 'Hoogte (px)', instructions: 'Minimaal 280px, maximaal 900px.', id: 'chatHeight', name: 'chatHeight', value: settings.chatHeight, placeholder: '400' }) }}

		{{ forms.textField({ label: 'Welkomstbericht', instructions: 'Deze tekst krijgt de gebruiker als eerste in de chat te zien. Tip: Gebruik {name} om de chatbotnaam in te voegen.', id: 'welcomeMessage', name: 'welcomeMessage', value: settings.welcomeMessage, placeholder: 'Hallo! Ik ben {name}. Hoe kan ik je helpen?', required: true }) }}
		
		<hr/>

		{{ forms.lightswitchField({ label: 'Gebruik fallback bericht', instructions: 'Schakel in om een vast bericht te tonen als de chatbot geen antwoord heeft. Schakel uit om de chatbot zelf een antwoord te laten formuleren.', id: 'useFallbackMessage', name: 'useFallbackMessage', on: settings.useFallbackMessage }) }}

		{{ forms.textareaField({ label: 'Fallback bericht', instructions: 'Bericht dat getoond wordt als de chatbot geen antwoord kan geven op basis van de beschikbare data.', id: 'fallbackMessage', name: 'fallbackMessage', value: settings.fallbackMessage, rows: 3, required: true }) }}
	</div>
</div>
