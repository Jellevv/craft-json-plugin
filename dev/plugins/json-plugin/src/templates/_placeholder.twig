<style>
  .chat-wrapper {
    position: fixed;
    bottom: 20px;
    right: 20px;
    width: 300px;
    height: 500px;
    display: flex;
    flex-direction: column;
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    z-index: 1000;
    transition: height 0.3s ease;
    background: white;
    font-family: Arial, sans-serif;
  }
  .chat-wrapper.collapsed { height: 60px; }
  .chat-header {
    height: 60px;
    background: #1f7a5c;
    color: white;
    padding: 0 15px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    flex-shrink: 0;
  }
  .chat-container {
    flex: 1;
    overflow-y: auto;
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #f5f5f5;
  }
  .chat-entry {
    max-width: 85%;
    padding: 10px 14px;
    border-radius: 18px;
    font-size: 14px;
    line-height: 1.4;
    word-wrap: break-word;
  }
  .chat-entry.user {
    align-self: flex-end;
    background: #1f7a5c;
    color: white;
    border-bottom-right-radius: 4px;
  }
  .chat-entry.assistant {
    align-self: flex-start;
    background: white;
    color: #333;
    border: 1px solid #ddd;
    border-bottom-left-radius: 4px;
  }
  .input-container {
    display: flex;
    padding: 10px;
    background: white;
    border-top: 1px solid #ccc;
    gap: 10px;
  }
  #vraag {
    flex: 1;
    padding: 10px;
    border-radius: 20px;
    border: 1px solid #ccc;
    outline: none;
  }
  #verstuur {
    padding: 10px 18px;
    border-radius: 20px;
    border: none;
    background: #1f7a5c;
    color: white;
    cursor: pointer;
    font-weight: bold;
  }
</style>

<div class="chat-wrapper collapsed">
  <header class="chat-header" id="chat-toggle">
    <h2 id="chat-header-text" style="margin:0; font-size: 20px;">Heeft u een vraag?</h2>
    <span id="chat-icon" style="font-size: 24px;">+</span>
  </header>

  <main id="chat-container" class="chat-container">
    <div class="chat-entry assistant">Hallo! Ik ben de GreenTech Assistant. Hoe kan ik je helpen?</div>
  </main>

  <div id="input-container" class="input-container">
    <input type="text" id="vraag" placeholder="Typ je vraag..." autocomplete="off" />
    <button id="verstuur">Verstuur</button>
  </div>
</div>

<script>
  (function () {
    const chatWrapper = document.querySelector('.chat-wrapper');
    const chatToggle = document.getElementById('chat-toggle');
    const chatIcon = document.getElementById('chat-icon');
    const chatHeaderText = document.getElementById('chat-header-text');
    const chatContainer = document.getElementById('chat-container');
    const vraagInput = document.getElementById('vraag');
    const verstuurButton = document.getElementById('verstuur');
  
    let sessionId = localStorage.getItem('chatSessionId') || Math.random().toString(36).substring(2, 15);
    localStorage.setItem('chatSessionId', sessionId);
  
    chatToggle.addEventListener('click', () => {
      const isCollapsed = chatWrapper.classList.toggle('collapsed');
      chatIcon.textContent = isCollapsed ? '+' : '-';
      chatHeaderText.textContent = isCollapsed ? 'Heeft u een vraag?' : 'GreenTech Assistant';
    });
  
    async function stuurVraag() {
      const vraagTekst = vraagInput.value.trim();
      if (!vraagTekst) return;
  
      // Gebruiker bericht tonen
      const userDiv = document.createElement('div');
      userDiv.className = 'chat-entry user';
      userDiv.textContent = vraagTekst;
      chatContainer.appendChild(userDiv);
  
      // Assistant "loading" bericht
      const assistantDiv = document.createElement('div');
      assistantDiv.className = 'chat-entry assistant';
      assistantDiv.textContent = 'Aan het typen...';
      chatContainer.appendChild(assistantDiv);
  
      vraagInput.value = '';
      chatContainer.scrollTop = chatContainer.scrollHeight;
  
      try {
        // LET OP: Geen poort 3000 meer, maar de Craft Action URL
        const response = await fetch('/actions/json-plugin/chat/vraag', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            vraag: vraagTekst,
            sessionId: sessionId
          })
        });

        if (!response.ok) throw new Error('Server error');
        
        const data = await response.json();
  
        // Markdown-ish styling naar HTML
        const parsedAntwoord = (data.antwoord || 'Geen antwoord ontvangen')
          .replace(/\[([^\]]+)\]\((https?:\/\/[^\s)]+)\)/g, '<a href="$2" target="_blank">$1</a>')
          .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
          .replace(/\n/g, '<br>');
  
        assistantDiv.innerHTML = parsedAntwoord;
      } catch (err) {
        console.error('Fout:', err);
        assistantDiv.textContent = 'Excuses, er ging iets mis bij het ophalen van het antwoord.';
      } finally {
        chatContainer.scrollTop = chatContainer.scrollHeight;
      }
    }
  
    verstuurButton.addEventListener('click', stuurVraag);
    vraagInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') stuurVraag();
    });
  })();
</script>
