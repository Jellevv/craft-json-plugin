{
  "name": "jelle/craft-json-plugin",
  "description": "AI Chatbot en JSON export voor Craft CMS",
  "type": "craft-plugin",
  "version": "1.0.0",
  "license": "MIT",
  "authors": [
    {
      "name": "Jelle",
      "role": "Developer"
    }
  ],
  "require": {
    "php": "^8.0.2",
    "craftcms/cms": "^5.0.0",
    "openai-php/client": "^0.19.0"
  },
  "autoload": {
    "psr-4": {
      "jelle\\craftjsonplugin\\": "src/"
    }
  },
  "extra": {
    "handle": "json-plugin",
    "name": "JSON Assistant",
    "developer": "Jelle",
    "hasCpSettings": true,
    "class": "jelle\\craftjsonplugin\\JsonPlugin",
    "components": {
      "jsonService": "jelle\\craftjsonplugin\\services\\JsonService"
    }
  }
}
